# Copy to .env and fill in values.
#
# Moonshot API key (required for agent_bot)
MOONSHOT_API_KEY=

# OpenAI-compatible base URL for Moonshot
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Model name
KIMI_MODEL=kimi-k2.5

# Thinking mode (per Moonshot API)
KIMI_THINKING_TYPE=disabled

# Bot behavior knobs
# If 0, LLM is only called when addressed in chat (recommended).
AGENT_LLM_TICK_MS=0
AGENT_REPLY_TO_ALL=false
AGENT_AUTO_APPROACH=true
AGENT_MIN_CHAT_INTERVAL_MS=5000
AGENT_GREETING=Hello, world!
AGENT_SYSTEM_PROMPT=You are a Magic creature.

# Where agent_bot talks to agent_bridge
BRIDGE_URL=http://127.0.0.1:5055

# Default nickname/avatar for created agents
EKZA_NICKNAME=Agent1
EKZA_AVATAR=https://ipfs.io/ipfs/QmYctsMK3iyHiAYEdPv4WuDv7FTiedmor5pj5pdV6vUvCN

# Optional: default addresses for server/bridge
EKZA_URL=http://127.0.0.1:3001
BRIDGE_BIND=127.0.0.1:5055

