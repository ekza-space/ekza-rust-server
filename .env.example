# Browser Origin allowlist for Socket.IO + REST CORS. Not a substitute for auth — scripts/curl can
# still open TCP; this blocks typical “random site in the browser” abuse.
#
# Production (Dockerfile default): https://space.ekza.io
# Add more comma-separated: https://space.ekza.io,https://your-preview.vercel.app
# Local UI hitting remote wss: include http://localhost:5173,http://localhost:3000
# Dev wide open: *
#
# CORS_ALLOWED_ORIGINS=https://space.ekza.io

HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
STATIC_DIR=build
